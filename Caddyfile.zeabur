# Zeabur K8s startup probe dials container port 80; zeabur/caddy-static defaults to 8080 only.
# Two explicit listeners avoid probe "connection refused" on :80.
# See https://zeabur.com/docs/en-US/deploy/networking/public-networking
:80 {
	root * /usr/share/caddy
	encode gzip zstd
	file_server
}

:8080 {
	root * /usr/share/caddy
	encode gzip zstd
	file_server
}
